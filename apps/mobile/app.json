{
  "expo": {
    "name": "Inner Atlas",
    "slug": "inner-atlas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "inner-atlas",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inneratlas.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Inner Atlas uses Face ID to protect your private data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.inneratlas.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Inner Atlas to access your photos to add images to your parts.",
          "cameraPermission": "Allow Inner Atlas to use your camera to capture images for your parts."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Inner Atlas to use Face ID to protect your private data."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8"
        }
      ]
    ],
    "assets": ["./assets/Bell.mp3"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe55f167-8c23-4dbf-89d1-86bdfe3bbc24"
      }
    }
  }
}
